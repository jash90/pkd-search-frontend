{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "esModuleInterop": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "strict": true,
    "lib": ["ES2022", "DOM"],
    "noEmit": true,
    "types": []
  },
  "include": ["**/*.ts", "**/*.tsx"]
}

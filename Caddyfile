{
	admin off
	auto_https off
}

:{$PORT:8080} {
	root * /srv

	encode zstd gzip

	# --- Canonical host: 301 www -> apex (Railway passes the original Host) ---
	@www host www.kodypkd.app
	redir @www https://kodypkd.app{uri} 308

	# --- Security headers (mirror vercel.json) ---
	header {
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
	}

	# --- Cache policy ---
	# Hashed assets: long-lived & immutable
	@assets path /assets/*
	header @assets Cache-Control "public, max-age=31536000, immutable"

	# Everything else (HTML, sitemaps, manifests): always revalidate
	@notAssets not path /assets/*
	header @notAssets Cache-Control "no-store"

	# --- Legacy URL redirects (replicate vercel.json "permanent: true") ---
	# Order matters: more-specific paths must come before catch-alls.
	# NOTE: the explicit `*` matcher is required — otherwise Caddy parses a
	# leading-slash first argument as a path matcher rather than the target.
	handle /search {
		redir * / 308
	}
	handle_path /search/* {
		redir * /kody-pkd{uri} 308
	}
	handle_path /szukaj/* {
		redir * /kody-pkd{uri} 308
	}
	handle /samples {
		redir * /przyklady 308
	}
	handle_path /samples/limit/* {
		redir * /przyklady/limit{uri} 308
	}
	handle_path /samples/* {
		redir * /przyklady/limit{uri} 308
	}

	# --- Legacy dynamic OG image endpoint ---
	# ~167 old /api/og?title=... URLs were indexed by Google before the switch
	# to a static card. They 404 now. Redirect them to the static image so they
	# resolve (200) instead of erroring. robots.txt no longer disallows /api/,
	# so Googlebot can follow this redirect and clear the 404s from Coverage.
	handle /api/og {
		redir * /og-default.png 308
	}

	# --- Legacy category-slug fixes ---
	# Old canonical derived the slug from the category label, which differed from
	# the real prerendered slug (e.g. "Sklep stacjonarny" -> sklep-stacjonarny,
	# but the page lives at /kody-pkd/sklep). Those URLs were indexed and 404.
	handle /kody-pkd/sklep-stacjonarny {
		redir * /kody-pkd/sklep 308
	}
	handle /kody-pkd/e-commerce-sklep-internetowy {
		redir * /kody-pkd/e-commerce 308
	}

	# --- Default request handling: extensionless prerendered URLs ---
	# /przyklady       -> /przyklady.html
	# /kody-pkd/x      -> /kody-pkd/x.html
	# /                -> /index.html (via directory match)
	handle {
		try_files {path} {path}.html {path}/index.html
		file_server {
			precompressed br gzip
		}
	}

	# --- 404 fallback: serve the prerendered 404 page with HTTP 404 status. ---
	handle_errors {
		@404 expression `{http.error.status_code} == 404`
		handle @404 {
			rewrite * /404.html
			file_server {
				precompressed br gzip
			}
		}
	}
}
